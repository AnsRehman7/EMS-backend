NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173,https://your-site.netlify.app

# Update the password/user to match your local PostgreSQL installation.
DATABASE_URL="postgresql://postgres:postgre@localhost:5432/postgres?schema=public"

# Firebase Admin verification. Prefer a service account in production.
# Option A: full service account JSON in one environment variable.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option B: base64-encoded service account JSON (recommended for Vercel).
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Option C: split service account values.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Option D: local path to a downloaded Firebase service account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=

# Local development fallback. This can be the same public web API key used by the Vite Firebase config.
FIREBASE_WEB_API_KEY=

# Optional: comma-separated emails that should become admins when first synced.
BOOTSTRAP_ADMIN_EMAILS=

# Keep false in production. Set true only for local demos that self-select roles.
ALLOW_CLIENT_ROLE_SELECTION=false

# Groq AI planning, task/project weightage, and progress analysis.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Attendance geofence. Mobile also uses these values for local UX.
OFFICE_LATITUDE=
OFFICE_LONGITUDE=
OFFICE_RADIUS_METERS=100
